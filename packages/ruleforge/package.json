{
  "name": "@ruleforge/core",
  "version": "1.0.0",
  "description": "NightShift RuleForge - 智能代码规则生成引擎",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest",
    "test:watch": "vitest --watch",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "prepublishOnly": "npm run build && npm run test"
  },
  "keywords": [
    "ruleforge",
    "code-analysis",
    "pattern-recognition",
    "yaml",
    "code-generation",
    "nightshift"
  ],
  "author": "NightShift Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/nightshift/nightshift-ruleforge"
  },
  "bugs": {
    "url": "https://github.com/nightshift/nightshift-ruleforge/issues"
  },
  "homepage": "https://github.com/nightshift/nightshift-ruleforge#readme",
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.0.0",
    "typescript": "^5.0.0",
    "vitest": "^1.0.0"
  },
  "peerDependencies": {},
  "engines": {
    "node": ">=18.0.0"
  }
}