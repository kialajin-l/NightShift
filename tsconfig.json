{
  "compilerOptions": {
    "target": "ES2022",
    "lib": [
      "dom",
      "dom.iterable",
      "ES2022"
    ],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "./src/*"
      ],
      "@nightshift/core": [
        "./packages/core/src"
      ],
      "@nightshift/agents": [
        "./packages/agents/src"
      ],
      "@nightshift/ruleforge": [
        "./packages/ruleforge/src"
      ],
      "@nightshift/ui": [
        "./packages/ui/src"
      ]
    },
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "exactOptionalPropertyTypes": false,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedIndexedAccess": false,
    "noImplicitOverride": true,
    "noPropertyAccessFromIndexSignature": false,
    "downlevelIteration": true
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "src/api-codepilot",
    "src/lib-codepilot",
    "src/components-codepilot",
    "src/hooks-codepilot",
    "src/types-codepilot",
    "src/app/api-codepilot",
    "**/__tests__/**",
    "**/demo/**",
    "**/*.test.ts",
    "**/*.test.tsx",
    "**/*.spec.ts",
    "**/*.spec.tsx",
    "**/vitest.config.ts",
    "**/vitest.isolated.config.ts",
    "packages"
  ]
}